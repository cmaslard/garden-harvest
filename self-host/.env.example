# Copy this file to .env (next to docker-compose.yml, on the NAS) and fill in
# every value below. Never commit the real .env — it holds live secrets.
#
# Generate POSTGRES_PASSWORD / JWT_SECRET / ANON_KEY / SERVICE_ROLE_KEY /
# DASHBOARD_PASSWORD / PG_META_CRYPTO_KEY with the upstream helper scripts:
#   sh utils/generate-keys.sh
#   sh utils/add-new-auth-keys.sh
# (run from the supabase/supabase docker/ project directory you copied onto the NAS)

############
# Postgres
############
POSTGRES_PASSWORD=
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

############
# JWT / API keys
# ANON_KEY is the value that replaces the current SUPABASE_ANON_KEY constant
# in index.html once you cut over (see RUNBOOK.md Phase 6).
############
JWT_SECRET=
ANON_KEY=
SERVICE_ROLE_KEY=

############
# Studio dashboard (basic-auth in front of Studio, via Kong)
############
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=

############
# postgres-meta (used internally by Studio)
############
PG_META_CRYPTO_KEY=

############
# URLs
############
# Local/internal smoke-test URL (Phase 1/4). Change to the public URL once
# exposed via Cloudflare Tunnel (Phase 5), e.g. https://supabase.cmaslard.xyz
SUPABASE_PUBLIC_URL=http://localhost:8000
API_EXTERNAL_URL=http://localhost:8000/auth/v1
# Same story: point this at the real public site URL before real users log in,
# since GoTrue uses it to build magic-link / password-recovery email links.
SITE_URL=https://cmaslard.xyz/garden-harvest/
ADDITIONAL_REDIRECT_URLS=

############
# Auth behaviour
############
JWT_EXPIRY=3600
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_ANONYMOUS_USERS=false

MAILER_URLPATHS_CONFIRMATION="/auth/v1/verify"
MAILER_URLPATHS_INVITE="/auth/v1/verify"
MAILER_URLPATHS_RECOVERY="/auth/v1/verify"
MAILER_URLPATHS_EMAIL_CHANGE="/auth/v1/verify"

# Only needed if magic-link / password-recovery email is actually used by
# garden-harvest (the UI has a "Magic link" tab). Point at a real SMTP relay —
# the values below are the upstream dev-only fake mail catcher and will not
# deliver real email. In production this project uses Gmail SMTP with an
# App Password (myaccount.google.com/apppasswords, needs 2-Step Verification
# enabled first) — smtp.gmail.com, port 587, SMTP_USER = the Gmail address,
# SMTP_PASS = the 16-char app password (no spaces).
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=supabase-mail
SMTP_PORT=2500
SMTP_USER=fake_mail_user
SMTP_PASS=fake_mail_password
SMTP_SENDER_NAME=garden-harvest

# Used by notifier/check.sh (see docker-compose.yml's "notifier" service) — the
# address that gets emailed whenever a new account signs up. Only meaningful
# once real SMTP_* values above are set.
ADMIN_EMAIL=admin@example.com

############
# Studio
############
STUDIO_DEFAULT_ORGANIZATION=garden-harvest
STUDIO_DEFAULT_PROJECT=garden-harvest
OPENAI_API_KEY=

############
# API (PostgREST) — schemas exposed via the REST API
# This is the self-host equivalent of Supabase Cloud's
# Settings -> API -> Exposed Schemas. Must include "garden" or every
# sb.schema('garden').from(...) call in index.html gets a 403/404.
############
PGRST_DB_SCHEMAS=garden,public,graphql_public
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public

############
# Kong (API gateway)
############
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
